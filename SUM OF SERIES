#include<stdio.h>

int main() {
    int n, i, sum = 0;

    printf("Enter n: ");
    scanf("%d", &n);

    // For loop
    for(i = 1; i <= n; i++) {
        sum += i;
    }
    printf("Sum using for loop = %d\n", sum);

    // While loop
    i = 1;
    sum = 0;
    while(i <= n) {
        sum += i;
        i++;
    }
    printf("Sum using while loop = %d", sum);

    return 0;
}

OUTPUT:Enter n=5
Sum using for loop = 15
Sum using while loop = 15
